# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/splex?schema=public"

# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN=7d

# Solapi (카카오 알림톡)
SOLAPI_API_KEY=""
SOLAPI_API_SECRET=""
SOLAPI_SENDER=""
SOLAPI_PFID=""

# Cloudinary (사진 업로드 - https://cloudinary.com 무료 플랜 25GB)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# CORS
CLIENT_ORIGIN="http://localhost:5173"
