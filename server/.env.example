# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/suplex?schema=public"

# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN=7d

# CORS — 콤마로 여러 origin 등록 가능
# 예) https://suplex.vercel.app,https://suplex-honeyyours.vercel.app
CLIENT_ORIGIN="http://localhost:5173"

# Anthropic (AI 비서)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Cloudinary (사진 업로드 - https://cloudinary.com 무료 플랜 25GB)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Solapi (카카오 알림톡 - 옵션)
SOLAPI_API_KEY=""
SOLAPI_API_SECRET=""
SOLAPI_SENDER=""
SOLAPI_PFID=""

# Resend (이메일 발송 - 비밀번호 재설정용)
# https://resend.com 가입 후 suplex.kr 도메인 인증(SPF/DKIM/DMARC) 완료 시 사용 가능.
# 미설정 시 비밀번호 재설정 메일 발송이 no-op로 처리됩니다.
RESEND_API_KEY=""
MAIL_FROM="Suplex <noreply@suplex.kr>"

# 메일 본문 링크 생성용 — 클라이언트 호스팅 도메인
APP_BASE_URL="http://localhost:5173"
