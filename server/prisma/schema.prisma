// Suplex Prisma Schema
// 소규모 인테리어 업체용 SaaS MVP

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. 회사 / 사용자 / 팀
// ============================================

model Company {
  id      String  @id @default(cuid())
  name    String
  phone   String?
  address String?

  // 견적 표시용 회사 정보 (갑지 우측 상단)
  email          String?
  bizNumber      String? // 사업자등록번호
  representative String? // 대표자명
  logoUrl        String? // 로고 (선택)

  // 견적 기본 비율 (% 단위) — 새 견적 작성 시 스냅샷으로 복사됨
  rateIndirectMaterial Decimal @default(2) @db.Decimal(5, 2) // (2) 간접재료비 (1)*X%
  rateIndirectLabor    Decimal @default(2) @db.Decimal(5, 2) // (5) 간접노무비 (4)*X%
  rateIndustrialAcc    Decimal @default(3.7) @db.Decimal(5, 2) // (8) 산재보험료 (6)*X%
  rateEmployment       Decimal @default(1.39) @db.Decimal(5, 2) // (9) 고용보험료 (4)*X%
  rateRetirement       Decimal @default(2.3) @db.Decimal(5, 2) // (10) 퇴직공제부금비 (4)*X%
  rateSafety           Decimal @default(2.93) @db.Decimal(5, 2) // (11) 안전관리비 [(1)+(4)]*X%
  rateOtherExpense     Decimal @default(2) @db.Decimal(5, 2) // (12) 기타경비 [(1)+(4)]*X%
  rateMisc             Decimal @default(5) @db.Decimal(5, 2) // (15) 공잡비 (14)*X%
  rateGeneralAdmin     Decimal @default(5) @db.Decimal(5, 2) // (16) 일반관리비 (14)*X%
  rateSupervision      Decimal @default(10) @db.Decimal(5, 2) // (17) 감리비 [(14)+(15)+(16)]*X%
  rateDesign           Decimal @default(2) @db.Decimal(5, 2) // (18) 디자인비 (14)*X%
  rateVat              Decimal @default(10) @db.Decimal(5, 2) // 부가가치세

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships            Membership[]
  invitations            Invitation[]
  vendors                Vendor[]
  projects               Project[]
  materialTemplates      MaterialTemplate[]
  phaseKeywordRules      PhaseKeywordRule[]
  quoteLineItemTemplates QuoteLineItemTemplate[]
  expenses               Expense[]
  accountCodes           AccountCode[]
  expenseCategoryRules   ExpenseCategoryRule[]
  phaseDeadlineRules     PhaseDeadlineRule[]
  phaseAdvices           PhaseAdvice[]

  @@map("companies")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships     Membership[]
  createdProjects Project[]         @relation("ProjectCreatedBy")
  materialChanges MaterialHistory[]
  scheduleTasks   ScheduleTask[]    @relation("TaskAssignee")
  dailyReports    DailyReport[]

  createdChecklists      ProjectChecklist[]    @relation("ChecklistCreatedBy")
  completedChecklists    ProjectChecklist[]    @relation("ChecklistCompletedBy")
  createdScheduleEntries DailyScheduleEntry[]  @relation("DailyScheduleCreatedBy")
  updatedScheduleEntries DailyScheduleEntry[]  @relation("DailyScheduleUpdatedBy")
  scheduleChanges        ScheduleChange[]
  uploadedPhotos         ProjectPhoto[]
  materialRequests       MaterialRequest[]
  createdQuotes          Quote[]               @relation("QuoteCreatedBy")
  createdExpenses        Expense[]             @relation("ExpenseCreatedBy")
  createdAccountCodes    AccountCode[]         @relation("AccountCodeCreatedBy")
  createdExpenseRules    ExpenseCategoryRule[] @relation("ExpenseRuleCreatedBy")
  applianceCorrections   ApplianceSpec[]       @relation("ApplianceSpecCorrectedBy")

  @@map("users")
}

enum Role {
  OWNER // 대표 - 전체 권한
  DESIGNER // 디자인팀 - 마감재/견적
  FIELD // 현장팀 - 현장보고/공정
}

// 사용자 ↔ 회사 다대다 (+ 역할)
model Membership {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      Role
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("memberships")
}

model Invitation {
  id         String    @id @default(cuid())
  companyId  String
  email      String
  role       Role
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("invitations")
}

// ============================================
// 2. 협력업체
// ============================================

model Vendor {
  id        String   @id @default(cuid())
  companyId String
  name      String // 업체명
  category  String // 공종 (전기, 설비, 타일 등)
  contact   String? // 담당자
  phone     String?
  unitPrice Decimal? @db.Decimal(12, 2)
  unit      String? // 단위 (m², 개, 일 등)
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company              Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  scheduleTasks        ScheduleTask[]
  expenses             Expense[]
  purchaseOrders       PurchaseOrder[]
  dailyScheduleEntries DailyScheduleEntry[]

  @@index([companyId, category])
  @@map("vendors")
}

// ============================================
// 3. 프로젝트
// ============================================

enum ProjectStatus {
  PLANNED // 예정
  IN_PROGRESS // 진행중
  ON_HOLD // 보류
  COMPLETED // 완료
  CANCELLED // 취소
}

model Project {
  id              String        @id @default(cuid())
  companyId       String
  createdById     String
  name            String // 프로젝트명 (예: 삼성동 OO아파트)
  customerName    String // 고객명
  customerPhone   String?
  siteAddress     String // 현장 주소
  contractAmount  Decimal?      @db.Decimal(14, 2) // 계약 금액
  startDate       DateTime? // 착공일
  expectedEndDate DateTime? // 준공 예정일
  actualEndDate   DateTime? // 실제 준공일
  status          ProjectStatus @default(PLANNED)
  doorPassword    String? // 출입번호
  siteNotes       String? // 현장정보 (주차, 엘리베이터 사용시간, 주의사항 등)
  area            Decimal?      @db.Decimal(8, 2) // 면적 (평) — 견적 평당 단가 계산용
  siteCode        String? // 회계 시스템 매칭용 외부 코드 (예: "2602_온스트릿")
  memo            String? // 기타 메모
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company              Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy            User                 @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  checklists           ProjectChecklist[]
  materials            Material[]
  schedules            Schedule[]
  dailyScheduleEntries DailyScheduleEntry[]
  scheduleChanges      ScheduleChange[]
  dailyReports         DailyReport[]
  measurements         Measurement[]
  notifications        Notification[]
  photos               ProjectPhoto[]
  materialRequests     MaterialRequest[]
  quotes               Quote[]
  simpleQuotes         SimpleQuote[]
  purchaseOrders       PurchaseOrder[]
  expenses             Expense[]
  projectMemos         ProjectMemo[]

  @@unique([companyId, siteCode])
  @@index([companyId, status])
  @@map("projects")
}

enum ChecklistCategory {
  GENERAL // 일반
  CLIENT_REQUEST // 고객 요청
  DESIGN_TO_FIELD // 디자인팀 → 현장팀 전달
  TOUCH_UP // 잔손
  URGENT // 긴급
}

// 프로젝트별 체크리스트 (사용자 관리 + PhaseAdvice 자동 생성 공용)
model ProjectChecklist {
  id               String            @id @default(cuid())
  projectId        String
  phase            String? // 공종 (철거/목공/전기 등) — 일정 카테고리와 매칭
  category         ChecklistCategory @default(GENERAL)
  title            String // 체크 항목 제목
  isDone           Boolean           @default(false)
  requiresPhoto    Boolean           @default(false) // 사진 첨부 필수 여부
  dueDate          DateTime?
  completedAt      DateTime?
  completedById    String?
  createdById      String?
  orderIndex       Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User?   @relation("ChecklistCreatedBy", fields: [createdById], references: [id])
  completedBy User?   @relation("ChecklistCompletedBy", fields: [completedById], references: [id])

  @@index([projectId, isDone])
  @@map("project_checklists")
}

// 회사별 키워드 → 공종(phase) 매핑.
// 일정 입력 시 content에서 키워드를 찾아 category 자동 설정 → 체크리스트 자동 트리거.
model PhaseKeywordRule {
  id        String   @id @default(cuid())
  companyId String
  keyword   String // 매칭할 키워드 (대소문자 무시, 부분 일치)
  phase     String // 매칭 시 부여할 공종 (철거/목공/...)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, keyword])
  @@index([companyId, active])
  @@map("phase_keyword_rules")
}

// (deprecated — 2026-04-26 PhaseAdvice로 통합 폐기)

// ============================================
// 3-2. 캘린더식 공정 일정 (날짜당 여러 항목, 개별 확정)
// ============================================

model DailyScheduleEntry {
  id          String    @id @default(cuid())
  projectId   String
  date        DateTime  @db.Date // 날짜 (시간 X)
  category    String? // 공종 태그 (목공/전기/타일/도배 등)
  content     String // 내용
  confirmed   Boolean   @default(false)
  confirmedAt DateTime?
  orderIndex  Int       @default(0)
  vendorId    String? // 협력업체 (선택)
  createdById String?
  updatedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor    Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdBy User?   @relation("DailyScheduleCreatedBy", fields: [createdById], references: [id])
  updatedBy User?   @relation("DailyScheduleUpdatedBy", fields: [updatedById], references: [id])

  @@index([projectId, date])
  @@index([category])
  @@index([vendorId])
  @@map("daily_schedule_entries")
}

enum ScheduleChangeAction {
  ADD
  UPDATE
  DELETE
  CONFIRM
  UNCONFIRM
}

model ScheduleChange {
  id            String               @id @default(cuid())
  projectId     String
  date          DateTime             @db.Date
  entryId       String? // 엔트리 삭제 후 null 가능
  action        ScheduleChangeAction
  oldContent    String?
  newContent    String?
  oldCategory   String?
  newCategory   String?
  changedById   String
  changedByName String // 비정규화 (사용자 이름 변경 대비)
  createdAt     DateTime             @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changedBy User    @relation(fields: [changedById], references: [id])

  @@index([projectId, createdAt])
  @@map("schedule_changes")
}

// ============================================
// 4. 마감재 (실제 현장 양식 기반)
// ============================================

// SpaceType: Measurement(실측)에서만 사용. Material은 spaceGroup 자유 문자열로 전환.
enum SpaceType {
  LIVING_ROOM
  KITCHEN
  MASTER_BEDROOM
  BEDROOM
  BATHROOM
  ENTRANCE
  OTHER
}

enum MaterialStatus {
  UNDECIDED // 미정 (legacy)
  REVIEWING // 확인중 (legacy, → 모델 확인 필요)
  CONFIRMED // 확정 (모델 정해짐)
  CHANGED // 변경 (legacy, → 확정)
  REUSED // 재사용 (기존 유지)
  NOT_APPLICABLE // 해당 없음
}

enum MaterialKind {
  FINISH // 마감재 (본표: 공간/공정 × 세부공정)
  APPLIANCE // 가전/가구 (별표: 구획 × 품목, 사이즈 포함)
}

model Material {
  id        String       @id @default(cuid())
  projectId String
  kind      MaterialKind @default(FINISH)

  spaceGroup String // 공간/공정 (거실, 조명, 필름, 주방, 욕실(공용) 등)
  subgroup   String? // 세부 그룹 (바닥·벽·천장, 조명·전기 등)
  itemName   String // 세부 공정 및 항목 (바닥재, 방문, 거실 다운라이트 등)
  essential  Boolean @default(false) // ●필수 vs ○옵션 (현재 UI에선 미사용)
  formKey    String? // 항목별 폼 매핑 키 (formSchemas.js의 키)

  brand                 String? // 브랜드 (legacy + 일부 폼이 사용)
  productName           String? // 모델/품번 (legacy + 일부 폼이 사용)
  spec                  String? // 규격 (legacy)
  customSpec            Json? // 폼별 맞춤 필드 값 (key→value)
  siteNotes             String? // 현장 시공 특이사항 (템플릿 디폴트, readonly hint)
  purchaseSource        String? // 매입처 (발주)
  checked               Boolean @default(false) // 체크(V) — 실물 확정 확인 표시
  inheritFromMaterialId String? // 공용부 동일 — 다른 Material(보통 거실) id 참조

  // APPLIANCE 전용 (가전/가구 별표)
  installed Boolean? // 설치 유무 O/X
  size      String? // W x D x H (mm)
  remarks   String? // 비고 (특이사항 / 빌트인 여부)

  // 공통 부가 (견적·수량)
  status     MaterialStatus @default(UNDECIDED)
  quantity   Decimal?       @db.Decimal(10, 2)
  unit       String?
  unitPrice  Decimal?       @db.Decimal(12, 2)
  totalPrice Decimal?       @db.Decimal(14, 2)
  memo       String?

  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  history        MaterialHistory[]
  purchaseOrders PurchaseOrder[]
  inheritFrom    Material?         @relation("MaterialInherit", fields: [inheritFromMaterialId], references: [id], onDelete: SetNull)
  inheritedBy    Material[]        @relation("MaterialInherit")

  @@index([projectId, kind, spaceGroup])
  @@index([inheritFromMaterialId])
  @@map("materials")
}

// 회사별 마감재 템플릿 — 신규 프로젝트 생성 시 이 목록에서 Material 자동 생성
model MaterialTemplate {
  id               String       @id @default(cuid())
  companyId        String
  kind             MaterialKind @default(FINISH)
  spaceGroup       String
  subgroup         String? // 세부 그룹 (바닥·벽·천장, 조명·전기 등)
  itemName         String
  formKey          String? // 항목별 폼 매핑 키 (Material.formKey와 동기)
  defaultSiteNotes String? // 시공 특이사항 기본 조언 (회사 표준)
  essential        Boolean      @default(false) // legacy
  orderIndex       Int          @default(0)
  active           Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, kind, orderIndex])
  @@map("material_templates")
}

model MaterialHistory {
  id          String   @id @default(cuid())
  materialId  String
  changedById String
  field       String // 바뀐 필드 (status, itemName 등)
  oldValue    String?
  newValue    String?
  createdAt   DateTime @default(now())

  material  Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  changedBy User     @relation(fields: [changedById], references: [id])

  @@index([materialId])
  @@map("material_history")
}

// ============================================
// 5. 공정 일정
// ============================================

enum TaskStatus {
  NOT_STARTED // 미시작
  IN_PROGRESS // 진행중
  DONE // 완료
  DELAYED // 지연
}

// 공정 (여러 공종을 묶는 단위)
model Schedule {
  id         String   @id @default(cuid())
  projectId  String
  name       String // 공정명
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   ScheduleTask[]

  @@index([projectId])
  @@map("schedules")
}

// 공종별 작업 (간트차트의 단위)
model ScheduleTask {
  id           String     @id @default(cuid())
  scheduleId   String
  assigneeId   String? // 담당자 (User)
  vendorId     String? // 협력업체
  category     String // 공종 (철거, 목공, 전기, 설비, 타일, 도배 등)
  title        String
  plannedStart DateTime
  plannedEnd   DateTime
  actualStart  DateTime?
  actualEnd    DateTime?
  status       TaskStatus @default(NOT_STARTED)
  progress     Int        @default(0) // 0~100
  memo         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  schedule Schedule    @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  assignee User?       @relation("TaskAssignee", fields: [assigneeId], references: [id])
  vendor   Vendor?     @relation(fields: [vendorId], references: [id])
  photos   TaskPhoto[]

  @@index([scheduleId])
  @@index([status])
  @@map("schedule_tasks")
}

model TaskPhoto {
  id        String   @id @default(cuid())
  taskId    String
  url       String
  caption   String?
  createdAt DateTime @default(now())

  task ScheduleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_photos")
}

// ============================================
// 6. 현장 보고
// ============================================

model DailyReport {
  id          String   @id @default(cuid())
  projectId   String
  authorId    String
  reportDate  DateTime @db.Date
  category    String // 공종
  progress    Int      @default(0) // 진행률 %
  workerCount Int? // 작업 인원 수
  caption     String? // 한 줄 캡션 — 카톡 보고 메시지에 들어감 (예: "거실/안방 마감 끝")
  memo        String? // (deprecated) 특이사항 — UI 제거됨, 데이터 호환성 위해 컬럼 유지
  nextDayPlan String? // (deprecated) 내일 예정 — UI 제거됨, 데이터 호환성 위해 컬럼 유지
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])
  // photos: ProjectPhoto(source=REPORT, sourceId=id) 로 연결

  @@index([projectId, reportDate])
  @@map("daily_reports")
}

// ============================================
// 6-2. 자재 발주 요청
// ============================================

enum MaterialRequestStatus {
  PENDING // 요청됨
  ORDERED // 발주됨
  DELIVERED // 납품됨
  CANCELLED // 취소
}

model MaterialRequest {
  id            String                @id @default(cuid())
  projectId     String
  requestedById String
  materialName  String // 필요 자재
  quantity      Decimal?              @db.Decimal(10, 2)
  unit          String?
  neededDate    DateTime?             @db.Date // 필요 날짜
  status        MaterialRequestStatus @default(PENDING)
  memo          String?
  notifyOwner   Boolean               @default(true)
  orderedAt     DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy User    @relation(fields: [requestedById], references: [id])
  // photos: ProjectPhoto(source=MATERIAL_REQUEST, sourceId=id)

  @@index([projectId, status])
  @@map("material_requests")
}

// ============================================
// 6-3. 사진 통합 (REPORT / ISSUE / MATERIAL_REQUEST 공용)
// ============================================

enum PhotoSource {
  REPORT
  MATERIAL_REQUEST
  CHECKLIST
}

model ProjectPhoto {
  id           String      @id @default(cuid())
  projectId    String
  source       PhotoSource
  sourceId     String // DailyReport / MaterialRequest / ProjectChecklist id
  url          String // Cloudinary URL (원본)
  thumbnailUrl String? // Cloudinary 변환 URL (썸네일)
  caption      String?
  uploadedById String
  createdAt    DateTime    @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedById], references: [id])

  @@index([projectId, createdAt])
  @@index([source, sourceId])
  @@map("project_photos")
}

// ============================================
// 7. 알림 (카카오 알림톡)
// ============================================

enum NotificationType {
  SCHEDULE_D7 // 공정 D-7
  SCHEDULE_D3 // 공정 D-3
  SCHEDULE_D1 // 공정 D-1
  MATERIAL_PENDING // 미확정 마감재
  CUSTOM // 커스텀
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id          String             @id @default(cuid())
  projectId   String
  type        NotificationType
  recipient   String // 수신 전화번호
  message     String
  status      NotificationStatus @default(PENDING)
  scheduledAt DateTime
  sentAt      DateTime?
  errorMsg    String?
  solapiMsgId String?
  createdAt   DateTime           @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@map("notifications")
}

// ============================================
// 8. 수량 계산기 (실측)
// ============================================

model Measurement {
  id          String    @id @default(cuid())
  projectId   String
  space       SpaceType
  width       Decimal   @db.Decimal(8, 2) // 가로 (m)
  length      Decimal   @db.Decimal(8, 2) // 세로 (m)
  height      Decimal   @db.Decimal(8, 2) // 천장고 (m)
  floorArea   Decimal?  @db.Decimal(10, 2) // 바닥 면적
  wallArea    Decimal?  @db.Decimal(10, 2) // 벽면적
  ceilingArea Decimal?  @db.Decimal(10, 2) // 천장면적
  memo        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("measurements")
}

// ============================================
// 9. 견적 v2 — 한국 인테리어 표준 양식 (갑지 + 원가내역서 18행 + 공종별 세부)
// ============================================

enum QuoteStatus {
  DRAFT // 작성중
  SENT // 발송 (1차/수정)
  FINAL // 최종
}

// 직접공사비 공종 (15종 고정 순서)
enum WorkType {
  START // 공사시작
  DEMOLITION // 철거
  PLUMBING // 설비
  GAS // 가스
  ELECTRIC // 전기
  FIRE // 소방
  CARPENTRY // 목공
  TILE // 타일
  BATHROOM // 욕실
  PAINTING // 도장
  FILM // 필름
  WALLPAPER // 도배
  FURNITURE // 가구
  FLOORING // 마루장판
  FINISHING // 공사마무리
}

model Quote {
  id        String      @id @default(cuid())
  projectId String
  title     String // "1차", "수정 1차", "최종" 등 자유 텍스트
  status    QuoteStatus @default(DRAFT)

  // ============ 갑지 (스냅샷 — 작성 시 Project/Company에서 복사) ============
  customerName          String
  customerPhone         String?
  siteAddress           String
  projectName           String // 공사명
  amountInWords         String? // 금액 한글 표기 (예: "사천오백칠십만원정")
  validUntil            DateTime? @db.Date
  constructionStartDate DateTime? @db.Date // 착공 예정일 (견적서 명시용)
  constructionEndDate   DateTime? @db.Date // 준공 예정일 (견적서 명시용)
  notes                 String? // 빨간 비고 (예: 붙박이장 가구류 필름 제외)
  terms                 String? // 견적조건 (예: 부가가치세 별도 / 견적외 공사 별도)
  area                  Decimal?  @db.Decimal(8, 2) // 면적 스냅샷 (평) — 평당단가 계산용

  // ============ 비율 스냅샷 (% 단위, 작성 시 회사 default 복사 — 견적별 수정 가능) ============
  rateIndirectMaterial Decimal @default(2) @db.Decimal(5, 2) // (2)
  rateIndirectLabor    Decimal @default(2) @db.Decimal(5, 2) // (5)
  rateIndustrialAcc    Decimal @default(3.7) @db.Decimal(5, 2) // (8)
  rateEmployment       Decimal @default(1.39) @db.Decimal(5, 2) // (9)
  rateRetirement       Decimal @default(2.3) @db.Decimal(5, 2) // (10)
  rateSafety           Decimal @default(2.93) @db.Decimal(5, 2) // (11)
  rateOtherExpense     Decimal @default(2) @db.Decimal(5, 2) // (12)
  rateMisc             Decimal @default(5) @db.Decimal(5, 2) // (15)
  rateGeneralAdmin     Decimal @default(5) @db.Decimal(5, 2) // (16)
  rateSupervision      Decimal @default(10) @db.Decimal(5, 2) // (17)
  rateDesign           Decimal @default(2) @db.Decimal(5, 2) // (18)
  rateVat              Decimal @default(10) @db.Decimal(5, 2)

  // ============ 자동계산 적용 여부 (체크박스) ============
  applyIndirectMaterial Boolean @default(false)
  applyIndirectLabor    Boolean @default(false)
  applyIndustrialAcc    Boolean @default(false)
  applyEmployment       Boolean @default(false)
  applyRetirement       Boolean @default(false)
  applySafety           Boolean @default(false)
  applyOtherExpense     Boolean @default(false)
  applyMisc             Boolean @default(false)
  applyGeneralAdmin     Boolean @default(false)
  applySupervision      Boolean @default(true)
  applyDesign           Boolean @default(false)

  // ============ 캐시 (저장 시 자동 갱신, 18행 + 공급가액/부가세/합계/절삭) ============
  totalDirectMaterial   Decimal @default(0) @db.Decimal(14, 2) // (1)
  totalIndirectMaterial Decimal @default(0) @db.Decimal(14, 2) // (2)
  totalMaterial         Decimal @default(0) @db.Decimal(14, 2) // (3)
  totalDirectLabor      Decimal @default(0) @db.Decimal(14, 2) // (4)
  totalIndirectLabor    Decimal @default(0) @db.Decimal(14, 2) // (5)
  totalLabor            Decimal @default(0) @db.Decimal(14, 2) // (6)
  totalDirectExpense    Decimal @default(0) @db.Decimal(14, 2) // (7) 기계경비 (라인의 경비합)
  totalIndustrialAcc    Decimal @default(0) @db.Decimal(14, 2) // (8)
  totalEmployment       Decimal @default(0) @db.Decimal(14, 2) // (9)
  totalRetirement       Decimal @default(0) @db.Decimal(14, 2) // (10)
  totalSafety           Decimal @default(0) @db.Decimal(14, 2) // (11)
  totalOtherExpense     Decimal @default(0) @db.Decimal(14, 2) // (12)
  totalExpense          Decimal @default(0) @db.Decimal(14, 2) // (13)
  totalDirect           Decimal @default(0) @db.Decimal(14, 2) // (14) 직접공사비계
  totalMisc             Decimal @default(0) @db.Decimal(14, 2) // (15)
  totalGeneralAdmin     Decimal @default(0) @db.Decimal(14, 2) // (16)
  totalSupervision      Decimal @default(0) @db.Decimal(14, 2) // (17)
  totalDesign           Decimal @default(0) @db.Decimal(14, 2) // (18)
  totalSupply           Decimal @default(0) @db.Decimal(14, 2) // 공급가액
  totalVat              Decimal @default(0) @db.Decimal(14, 2) // 부가세 (별도 표시)
  totalFinal            Decimal @default(0) @db.Decimal(14, 2) // 합계 (절삭 후)
  totalRoundOff         Decimal @default(0) @db.Decimal(14, 2) // 절삭 차액 (공급가액 - 합계)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  lines     QuoteLineItem[]

  @@index([projectId, createdAt])
  @@map("quotes")
}

// 견적 세부 행 — 공종별로 그룹핑되며, 각 행은 수량 × 단가
model QuoteLineItem {
  id       String   @id @default(cuid())
  quoteId  String
  workType WorkType // 어느 공종 (15종)

  itemName String // 항목명 (예: "주방 상부장", "장판")
  spec     String? // 규격 (예: "한솔 패트 무광 크림화이트 기준")
  unit     String? // 단위 (m, m², 식, 개, 구...)
  quantity Decimal @default(1) @db.Decimal(10, 2) // 수량

  // 단가 (사용자 입력)
  materialUnitPrice Decimal @default(0) @db.Decimal(14, 2)
  laborUnitPrice    Decimal @default(0) @db.Decimal(14, 2)
  expenseUnitPrice  Decimal @default(0) @db.Decimal(14, 2)

  // 금액 (수량 × 단가, 캐시)
  materialCost Decimal @default(0) @db.Decimal(14, 2)
  laborCost    Decimal @default(0) @db.Decimal(14, 2)
  expenseCost  Decimal @default(0) @db.Decimal(14, 2)

  notes      String?
  orderIndex Int     @default(0)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, workType, orderIndex])
  @@map("quote_line_items")
}

// ============================================
// 10. 발주 예정 / 지출 (마감재 확정 시 자동 생성, 즉흥 발주도 가능)
// ============================================

enum PurchaseOrderStatus {
  PENDING // 대기중 (발주 예정)
  ORDERED // 발주완료
  RECEIVED // 수령
  CANCELLED // 취소
}

model PurchaseOrder {
  id         String  @id @default(cuid())
  projectId  String
  materialId String? // 연결된 마감재 (즉흥 발주는 null)

  // 항목 정보 (마감재에서 스냅샷 또는 사용자 직접 입력)
  itemName String // 표시명 (예: "거실 · 바닥재")
  spec     String? // 규격/제품명/브랜드 통합
  vendor   String? // 거래처 텍스트 (= Material.purchaseSource, vendor 미연결시 fallback)
  vendorId String? // 협력업체 마스터 연결 (선택)

  quantity   Decimal? @db.Decimal(10, 2)
  unit       String?
  unitPrice  Decimal? @db.Decimal(12, 2)
  totalPrice Decimal? @db.Decimal(14, 2)

  status PurchaseOrderStatus @default(PENDING)
  notes  String?

  expectedDate DateTime? @db.Date // 발주 예정일
  orderedAt    DateTime?
  receivedAt   DateTime?

  // 마감재 변경 감지: PO 생성 후 마감재가 수정되었을 때 ⚠️ 표시 (발주완료/수령 상태 PO만)
  materialChangedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  material     Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)
  vendorEntity Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  expenses     Expense[]

  @@index([projectId, status])
  @@index([materialId])
  @@index([vendorId])
  @@map("purchase_orders")
}

// ============================================
// 10-2. 지출 (실제 돈 나간 트랜잭션)
// ============================================

enum PaymentMethod {
  CASH // 현금
  CARD // 카드
  BANK_TRANSFER // 계좌이체
  OTHER
}

enum ExpenseType {
  EXPENSE // 지출
  INCOME // 매출/입금
  TRANSFER // 자금 이체 (집계에서 제외)
}

// 회사별 계정과목 마스터 (회계 분류 체계)
model AccountCode {
  id          String   @id @default(cuid())
  companyId   String
  code        String // 예: "[본사] 복리후생비", "[현장] 자재비"
  groupName   String? // 예: "본사" / "현장" / "대표" / "매출" / "자금" / "기타"
  active      Boolean  @default(true)
  orderIndex  Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User?                 @relation("AccountCodeCreatedBy", fields: [createdById], references: [id])
  expenses  Expense[]
  rules     ExpenseCategoryRule[]

  @@unique([companyId, code])
  @@index([companyId, groupName])
  @@map("account_codes")
}

// 자동분류 룰 (키워드 → 계정/현장/공종)
model ExpenseCategoryRule {
  id            String   @id @default(cuid())
  companyId     String
  keyword       String // 매칭할 키워드 (대소문자 무관, contains)
  accountCodeId String? // 자동 설정할 계정
  siteCode      String? // 자동 설정할 현장 (Project.siteCode와 매칭)
  workCategory  String? // 자동 설정할 공종 (Expense.workCategory string)
  priority      Int      @default(0) // 충돌 시 우선순위 (높을수록 우선)
  active        Boolean  @default(true)
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountCode AccountCode? @relation(fields: [accountCodeId], references: [id], onDelete: SetNull)
  createdBy   User?        @relation("ExpenseRuleCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, active])
  @@map("expense_category_rules")
}

model Expense {
  id        String  @id @default(cuid())
  companyId String
  projectId String? // null = 본사/대표 운영비 (회사 일반)

  date          DateTime       @db.Date
  amount        Decimal        @db.Decimal(14, 2) // 양수만 (type으로 부호 의미 구분)
  type          ExpenseType    @default(EXPENSE) // 지출/매출/이체
  vendor        String? // 거래처 텍스트 (vendor 미연결 시 fallback, CSV 가져오기 등)
  vendorId      String? // 협력업체 마스터 연결 (선택)
  accountCodeId String? // 계정과목 (회사 마스터에서 선택)
  workCategory  String? // 공종 (자유 string, 예: "전기/조명공사")
  description   String? // 내역(적요)
  paymentMethod PaymentMethod?
  receiptUrl    String? // 영수증 사진 URL

  purchaseOrderId String?

  // 가져오기 메타
  importedFrom String? // "통장CSV", "엑셀", "수동" 등
  rawText      String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  accountCode   AccountCode?   @relation(fields: [accountCodeId], references: [id], onDelete: SetNull)
  vendorEntity  Vendor?        @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  createdBy     User?          @relation("ExpenseCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, date])
  @@index([projectId, date])
  @@index([accountCodeId])
  @@index([vendorId])
  @@index([type])
  @@map("expenses")
}

// 회사 마스터 — 자주 쓰는 자재/단가 저장. 견적 작성 시 가져와서 라인으로 추가.
model QuoteLineItemTemplate {
  id        String   @id @default(cuid())
  companyId String
  workType  WorkType

  itemName             String
  spec                 String?
  unit                 String?
  defaultQuantity      Decimal @default(1) @db.Decimal(10, 2)
  defaultMaterialPrice Decimal @default(0) @db.Decimal(14, 2)
  defaultLaborPrice    Decimal @default(0) @db.Decimal(14, 2)
  defaultExpensePrice  Decimal @default(0) @db.Decimal(14, 2)

  active     Boolean  @default(true)
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, workType, orderIndex])
  @@map("quote_line_item_templates")
}

// ============================================
// 간편 견적서 (SimpleQuote) — 공정 기반 1장짜리 견적
// 상세 견적(Quote)와 별도 모델. 공정을 척추로 하는 신규 흐름.
// ============================================

enum SimpleQuoteStatus {
  DRAFT // 작성 중
  SENT // 발송됨 (고객 전달 완료)
  ACCEPTED // 수주 확정
  SUPERSEDED // 다음 차수로 대체됨
}

model SimpleQuote {
  id        String            @id @default(cuid())
  projectId String
  title     String // "1차" / "수정 1차" / "최종" 등 자유 텍스트
  status    SimpleQuoteStatus @default(DRAFT)
  quoteDate DateTime          @default(now()) @db.Date

  // 공급자 (스냅샷 — 작성 시 Company에서 복사)
  supplierName    String
  supplierRegNo   String?
  supplierOwner   String?
  supplierAddress String?
  supplierTel     String?
  supplierEmail   String?
  supplierLogoUrl String?

  // 수신자 / 프로젝트 표시명
  clientName  String
  projectName String

  // 합계 조정
  designFeeRate   Decimal @default(10) @db.Decimal(5, 2) // 디자인 및 감리비 % (0이면 미적용)
  vatRate         Decimal @default(0) @db.Decimal(5, 2) // 부가세 % — 기본 0 (별도 안내문이 표준), 필요 시 사용자가 입력
  roundAdjustment Decimal @default(0) @db.Decimal(14, 2) // 단수조정 (음수 가능)

  // 양식
  templateKey String  @default("classic") // classic / modern 등
  footerNotes String? // 하단 안내문

  // 캐시 (자동 계산, PATCH 시 재계산)
  subtotal        Decimal @default(0) @db.Decimal(14, 2) // 라인 합계
  designFeeAmount Decimal @default(0) @db.Decimal(14, 2)
  vatAmount       Decimal @default(0) @db.Decimal(14, 2)
  total           Decimal @default(0) @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lines   SimpleQuoteLine[]

  @@index([projectId, createdAt])
  @@map("simple_quotes")
}

model SimpleQuoteLine {
  id         String @id @default(cuid())
  quoteId    String
  orderIndex Int    @default(0)

  // true면 상위 그룹 헤더 (예: "화장실"). 수량/단가/금액 무시하고 합계에서 제외.
  isGroup    Boolean @default(false)
  // isGroup=true 인 라인 중 isGroupEnd=true → 그룹 종료 마커 (UI: 가는 구분선)
  isGroupEnd Boolean @default(false)

  itemName  String  // 품명 (= 공정명/그룹명)
  spec      String? // 규격 (보통 비움)
  quantity  Decimal @default(1) @db.Decimal(10, 2)
  unit      String? // "식" / "m²" / "개" 등
  unitPrice Decimal @default(0) @db.Decimal(14, 2)
  amount    Decimal @default(0) @db.Decimal(14, 2) // quantity × unitPrice (캐시)
  notes     String? // 비고

  quote SimpleQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, orderIndex])
  @@map("simple_quote_lines")
}

// ============================================
// 프로젝트 메모 — Google Keep 같은 다중 메모 카드
// 자유 텍스트(줄바꿈은 사용자가 직접 입력)
// ============================================
model ProjectMemo {
  id         String   @id @default(cuid())
  projectId  String
  title      String?
  content    String   // 메모 본문 (자유 형식, 줄바꿈은 사용자 입력 그대로)
  tag        String?  // 분류 — 일반/회고/AS/피드백 (자유 문자열, null 허용). AI 어드바이스 입력 신호로 사용.
  pinned     Boolean  @default(false)
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, orderIndex])
  @@index([projectId, tag])
  @@map("project_memos")
}

// ============================================
// 공정별 발주 데드라인 룰 (회사 단위 커스텀)
// 자재가 공정 시작 며칠 전까지 도착해야 하는지
// 회사 룰이 없으면 services/phaseDeadlines.js의 표준 상수 fallback
// ============================================
model PhaseDeadlineRule {
  id         String   @id @default(cuid())
  companyId  String
  phase      String   // 공정명 (정확 일치 + 부분 매칭 폴백)
  daysBefore Int      // 발주 데드라인 = 일정 시작일 - daysBefore
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, phase])
  @@map("phase_deadline_rules")
}

// ============================================
// 공정별 사전 어드바이스 (회사 단위)
// 일정 entry 생성/수정 시 (entry.date - daysBefore) 날짜에 체크리스트 자동 추가
// ============================================
model PhaseAdvice {
  id            String   @id @default(cuid())
  companyId     String
  phase         String   // 공정명 (entry.category 와 매칭)
  daysBefore    Int      // 일정 시작 며칠 전 (음수면 시작 후, 0이면 시작 당일 = 옛 ChecklistTemplate)
  title         String   // 체크리스트 제목 (예: "보양 관련 관리실 문의")
  description   String?  // 상세 설명
  category      String?  // 안전 / 자재 / 관리실 협의 / 사전 준비 등
  requiresPhoto Boolean  @default(false) // 사진 첨부 필수 — 시공 사진 증거용 (옛 ChecklistTemplate.requiresPhoto)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, phase])
  @@map("phase_advices")
}

// ============================================
// 가전 규격 DB (글로벌, 회사 공유)
// 모델명 → 검증된 사이즈 자동 채움
// 100% 정확도 가드레일: 다중 출처 합의 + 사용자 정정 + 출처 만료
// ============================================
model ApplianceSpec {
  id           String   @id @default(cuid())
  category     String   // REFRIGERATOR | KIMCHI_REFRIGERATOR | DISHWASHER | WASHING_MACHINE | DRYER | OVEN | COOKTOP | AIR_CONDITIONER | ROBOT_VACUUM
  brand        String   // "LG" | "삼성" | ...
  modelCode    String   @unique // 정확 모델코드 (예: S634S30Q)
  modelAliases String[] @default([]) // 별칭/약어 검색용
  productName  String   // "디오스 양문형 800L"

  // 외형 치수 (mm)
  widthMm  Int
  heightMm Int
  depthMm  Int

  // 설치 요구사항 (정확도 핵심)
  hingeOpenWidthMm Int? // 문 열림 시 필요 폭
  ventTopMm        Int? // 상부 통풍 간극
  ventSideMm       Int? // 측면 통풍 간극
  ventBackMm       Int? // 후면 통풍 간극

  // 카테고리별 메타
  doorType     String? // SIDE_BY_SIDE | FRENCH_DOOR | 4_DOOR | TOP_FREEZER 등
  capacityL    Int?
  builtIn      Boolean @default(false)
  releaseYear  Int?
  discontinued Boolean @default(false)

  // 검증 메타 (가드레일)
  sources        Json   @default("[]") // [{tier, url, scrapedAt, value}]
  consensusCount Int    @default(0) // 일치하는 출처 수
  verifyStatus   String @default("PENDING") // VERIFIED | PENDING | DISPUTED | USER_CORRECTED
  lastVerifiedAt DateTime?
  correctedById  String?
  correctedAt    DateTime?
  correctionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  correctedBy User? @relation("ApplianceSpecCorrectedBy", fields: [correctedById], references: [id], onDelete: SetNull)

  @@index([category, brand])
  @@index([modelCode])
  @@map("appliance_specs")
}
