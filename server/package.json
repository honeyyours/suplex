{
  "name": "suplex-server",
  "version": "0.1.0",
  "private": true,
  "description": "Suplex backend API",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "prisma db push --skip-generate && node scripts/seed-project-members.js && node src/server.js",
